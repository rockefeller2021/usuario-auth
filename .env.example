# Environment variables for usuario-auth
# Copy this file to .env and fill in real values before running.

# Server
PORT=8080
ENV=development          # "development" = text logs | "production" = JSON logs

# JWT — Use at least 32 random bytes for each secret in production.
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change_me_access_super_secret_32ch
JWT_REFRESH_SECRET=change_me_refresh_super_secret_32c

# MySQL — Repository backend
# Set REPO=mysql to use MySQL, leave empty or set REPO=memory for in-memory.
REPO=mysql
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=Isaac2013*
MYSQL_DATABASE=usuario_auth
